# Google Gemini (Required for natural language parsing)
GOOGLE_API_KEY="your-google-api-key"

# OpenAI (Optional - for GPT-5.4 models)
OPENAI_API_KEY="your-openai-api-key"

# Anthropic (Optional - for Claude 4.6 models)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Pulumi (Optional - if using a remote Pulumi backend)
PULUMI_ACCESS_TOKEN="your-pulumi-access-token"

# Local Network Docker (e.g., ssh://user@ip)
DOCKER_HOST="ssh://user@hostname"

# --- NOTIFICATION AND MONITORING ---
# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"

# --- INFRASTRUCTURE OVERRIDES ---
# (Optional) Override settings.yaml defaults for containerized environments
TEMPORAL_HOST="temporal"
QDRANT_HOST="qdrant"
REDIS_HOST="redis"

# --- AGENT WORKSPACE ---
# Default repository where agent workers persist their output as subfolders
AGENT_DEFAULT_REPO="ssh://git@github.com/rinehardramos/workspaces.git"

# --- CONTINUOUS INTEGRATION ---
# GitHub Access Token (Required for CI/CD pipeline actions, agent git push, and accessing workflow logs)
GITHUB_TOKEN="your-github-personal-access-token"
# Backward compat alias (some tools expect GH_TOKEN)
GH_TOKEN="${GITHUB_TOKEN}"

# --- OPIK OBSERVABILITY (Self-Hosted) ---
# URL for Opik backend API (used by SDK to send traces)
OPIK_URL_OVERRIDE="http://192.168.100.249:8080"
# Project name for trace grouping in Opik UI
OPIK_PROJECT_NAME="ai-orchestration"
# Opik version (defaults to latest)
OPIK_VERSION="latest"
