{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "title": "Architectural Insights (Next Improvements)",
  "uid": "architectural-insights-01",
  "panels": [
    {
      "title": "L1 Cache Hit Ratio",
      "type": "gauge",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(worker_cache_hits_total[5m])) / (sum(rate(worker_cache_hits_total[5m])) + sum(rate(worker_cache_misses_total[5m]))) * 100",
          "legendFormat": "Hit Ratio %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Average Task Duration (Seconds)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rate(worker_task_duration_seconds_sum[5m]) / rate(worker_task_duration_seconds_count[5m])",
          "legendFormat": "Duration (s)"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Temporal API Latency",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rate(temporal_api_latency_seconds_sum[5m]) / rate(temporal_api_latency_seconds_count[5m])",
          "legendFormat": "Latency (s)"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Active Temporal Workflows",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "workflow_active_total",
          "legendFormat": "Workflows"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ],
  "schemaVersion": 38,
  "timezone": "browser",
  "refresh": "5s"
}
